	<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .no-border-tonal-shift { border: none !important; }
        .tonal-layering { border: none !important; }
        .flat-no-shadows { box-shadow: none !important; }
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3, .headline { font-family: 'Manrope', sans-serif; }
    </style>

<aside class=" d-none d-md-block p-4 space-y-2 h-screen w-64 fixed bg-white dark:bg-slate-900 border-r-0 tonal-shift-bg-slate-100">
<nav class="d-flex flex-col py-30 px-0">
    <NavLink class="flex items-center space-x-3 px-4 py-3 text-slate-600 dark:text-slate-400 font-manrope text-sm font-semibold duration-150" 
             href="/" Match="NavLinkMatch.All">
        <span class="material-symbols-outlined" data-icon="dashboard">dashboard</span>
        <span>Dashboard</span>
    </NavLink>

    <NavLink class="flex items-center space-x-3 px-4 py-3 text-slate-600 dark:text-slate-400 font-manrope text-sm font-semibold hover:bg-slate-50 dark:hover:bg-slate-800 transition-all active:translate-x-1 duration-150" 
             href="/send">
        <span class="material-symbols-outlined" data-icon="send">send</span>
        <span>Send Money</span>
    </NavLink>

    <NavLink class="flex items-center space-x-3 px-4 py-3 text-slate-600 dark:text-slate-400 font-manrope text-sm font-semibold hover:bg-slate-50 dark:hover:bg-slate-800 transition-all active:translate-x-1 duration-150" 
             href="/receive">
        <span class="material-symbols-outlined" data-icon="qr_code_2">qr_code_2</span>
        <span>Receive Money</span>
    </NavLink>
</nav>
</aside>


<!-- BottomNavBar (Mobile Only) -->
<nav class="md:hidden fixed bottom-0 left-0 w-full z-60 flex justify-around items-center px-4 pb-6 pt-3 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl shadow-[0_-10px_30px_rgba(0,0,0,0.04)] no-border tonal-layering rounded-t-3xl">
    
    <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
        <span class="material-symbols-outlined">home</span>
        <span class="nav-text">Home</span>
    </NavLink>

    <NavLink class="nav-item" href="/send">
        <span class="material-symbols-outlined">payments</span>
        <span class="nav-text">Send</span>
    </NavLink>

    <NavLink class="nav-item" href="/receive">
        <span class="material-symbols-outlined">qr_code_scanner</span>
        <span class="nav-text">Receive</span>
    </NavLink>

    <NavLink class="nav-item" href="/profile">
        <span class="material-symbols-outlined">account_circle</span>
        <span class="nav-text">Profile</span>
    </NavLink>

</nav>

