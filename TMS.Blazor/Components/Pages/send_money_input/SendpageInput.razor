@page "/send"
<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Send Money | Digital Private Bank</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "surface-container-lowest": "#ffffff",
                    "primary-fixed-dim": "#b7c4ff",
                    "tertiary": "#952200",
                    "secondary-container": "#dae2fd",
                    "on-tertiary-container": "#ffddd5",
                    "primary": "#003ec7",
                    "on-background": "#191c1e",
                    "surface-tint": "#004ced",
                    "outline": "#737688",
                    "surface-container-high": "#e6e8ea",
                    "on-primary-container": "#dfe3ff",
                    "on-secondary-container": "#5c647a",
                    "surface-container-highest": "#e0e3e5",
                    "on-error": "#ffffff",
                    "secondary-fixed-dim": "#bec6e0",
                    "inverse-primary": "#b7c4ff",
                    "on-secondary-fixed-variant": "#3f465c",
                    "on-tertiary-fixed-variant": "#891e00",
                    "surface-dim": "#d8dadc",
                    "tertiary-fixed-dim": "#ffb4a1",
                    "on-secondary": "#ffffff",
                    "error-container": "#ffdad6",
                    "error": "#ba1a1a",
                    "surface": "#f7f9fb",
                    "surface-bright": "#f7f9fb",
                    "on-secondary-fixed": "#131b2e",
                    "surface-container-low": "#f2f4f6",
                    "on-tertiary": "#ffffff",
                    "tertiary-container": "#bf3003",
                    "on-primary-fixed": "#001452",
                    "on-surface": "#191c1e",
                    "on-tertiary-fixed": "#3c0800",
                    "secondary": "#565e74",
                    "secondary-fixed": "#dae2fd",
                    "inverse-on-surface": "#eff1f3",
                    "surface-container": "#eceef0",
                    "tertiary-fixed": "#ffdbd2",
                    "inverse-surface": "#2d3133",
                    "primary-container": "#0052ff",
                    "on-error-container": "#93000a",
                    "on-primary": "#ffffff",
                    "outline-variant": "#c3c5d9",
                    "on-primary-fixed-variant": "#0038b6",
                    "surface-variant": "#e0e3e5",
                    "on-surface-variant": "#434656",
                    "primary-fixed": "#dde1ff",
                    "background": "#f7f9fb"
            },
            "borderRadius": {
                    "DEFAULT": "0.125rem",
                    "lg": "0.25rem",
                    "xl": "0.5rem",
                    "full": "0.75rem"
            },
            "fontFamily": {
                    "headline": ["Manrope"],
                    "body": ["Inter"],
                    "label": ["Inter"]
            }
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .no-border-tonal-shift { border: none !important; }
        .tonal-layering { border: none !important; }
    </style>
</head>
<main class="flex-1 md:ml-64 px-6 py-8 max-w-5xl w-full pb-32">
<!-- Transaction Context -->
<div class="mb-12">
<h1 class="font-headline text-4xl font-extrabold text-on-surface tracking-tight mb-2">Send Money</h1>
<p class="text-on-surface-variant text-lg">Securely transfer funds to any account globally.</p>
</div>
<!-- Wealth Card: Source Account (Simplified for Context) -->
<section class="mb-10 p-8 rounded-[1.5rem] bg-gradient-to-br from-primary to-primary-container text-white relative overflow-hidden shadow-xl shadow-primary/20">
<div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -mr-20 -mt-20 blur-3xl"></div>
<div class="relative z-10 flex justify-between items-start mb-8">
<div>
<span class="font-label text-xs font-medium uppercase tracking-widest opacity-80">Primary Wealth Account</span>
<p class="font-headline text-lg font-bold">**** 8842</p>
</div>
<span class="material-symbols-outlined text-3xl">account_balance_wallet</span>
</div>
<div class="relative z-10">
<span class="font-label text-xs opacity-80">Available Balance</span>
<div class="font-headline text-4xl font-extrabold tracking-tight mt-1">
                    $124,500<span class="text-xl opacity-60">.00</span>
</div>
</div>
</section>
<!-- Transfer Form -->
<div class="space-y-12">

<!-- Account Field -->
<div class="group">
<label class="block font-label text-sm font-semibold text-on-surface-variant mb-4 ml-1">Receiver Account Number</label>
<div class="relative bg-surface-container-lowest p-6 rounded-xl shadow-sm group-focus-within:ring-2 ring-primary/10 transition-all">
<div class="flex items-center">
<span class="material-symbols-outlined text-primary mr-4">person_search</span>
<input class="w-full bg-transparent border-none focus:ring-0 text-xl font-headline font-bold text-on-surface placeholder:text-outline-variant p-0" placeholder="Enter Account ID" type="text"/>
</div>
<div class="absolute bottom-0 left-6 right-6 h-[2px] bg-outline-variant/30 group-focus-within:bg-primary transition-colors"></div>
</div>
</div>
<!-- Amount Field -->
<div>
<label class="block font-label text-sm font-semibold text-on-surface-variant mb-4 ml-1">Amount to Transfer</label>
<div class="relative bg-surface-container-lowest p-10 rounded-[1.5rem] shadow-sm flex flex-col items-center">
<div class="flex items-baseline mb-2">
<span class="font-headline text-4xl font-extrabold text-outline-variant mr-2">$</span>
<input class="w-full bg-transparent border-none focus:ring-0 text-6xl font-headline font-extrabold text-on-surface placeholder:text-outline-variant/30 text-center [appearance:textfield] [&amp;::-webkit-outer-spin-button]:appearance-none [&amp;::-webkit-inner-spin-button]:appearance-none" placeholder="0.00" type="number"/>
</div>
<p class="text-xs font-label text-on-surface-variant mt-2">Zero transaction fees for private accounts</p>
</div>
</div>
<!-- Action Button -->
<div class="pt-8">
<button class="w-full py-5 rounded-[1.5rem] bg-gradient-to-r from-primary to-primary-container text-white font-headline text-xl font-extrabold shadow-lg shadow-primary/30 hover:scale-[1.02] active:scale-95 transition-all flex items-center justify-center space-x-3">
<span>Review Transaction</span>
<span class="material-symbols-outlined text-2xl" data-weight="fill">arrow_forward</span>
</button>
<p class="text-center mt-6 text-sm text-on-surface-variant">
                    Transactions are protected by <span class="text-primary font-semibold">BankGrade™ Encryption</span>
</p>
</div>
</div>
</main>
<!-- BottomNavBar: Mobile Navigation Shell -->
<nav class="md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl shadow-[0_-10px_30px_rgba(0,0,0,0.04)] rounded-t-3xl">
<a class="flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 p-2" href="#">
<span class="material-symbols-outlined mb-1">home</span>
<span class="font-inter text-[10px] font-medium tracking-wide">Home</span>
</a>
<a class="flex flex-col items-center justify-center bg-blue-600 text-white rounded-2xl p-2 scale-110 -translate-y-2 shadow-lg shadow-blue-500/30" href="#">
<span class="material-symbols-outlined mb-1" style="font-variation-settings: 'FILL' 1;">payments</span>
<span class="font-inter text-[10px] font-medium tracking-wide">Send</span>
</a>
<a class="flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 p-2" href="#">
<span class="material-symbols-outlined mb-1">qr_code_scanner</span>
<span class="font-inter text-[10px] font-medium tracking-wide">Receive</span>
</a>
<a class="flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 p-2" href="#">
<span class="material-symbols-outlined mb-1">account_circle</span>
<span class="font-inter text-[10px] font-medium tracking-wide">Profile</span>
</a>
</nav>
<!-- Fixed Glass Background Element -->
<div class="fixed top-0 left-0 w-full h-full -z-10 pointer-events-none opacity-40">
<div class="absolute top-[10%] left-[-10%] w-[500px] h-[500px] bg-primary/5 rounded-full blur-[120px]"></div>
<div class="absolute bottom-[20%] right-[-5%] w-[400px] h-[400px] bg-primary-container/5 rounded-full blur-[100px]"></div>
</div>
</html>

