@page "/dashboard"
@page "/"
@rendermode InteractiveServer

<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Digital Private Bank - Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "surface-container-lowest": "#ffffff",
                        "primary-fixed-dim": "#b7c4ff",
                        "tertiary": "#952200",
                        "secondary-container": "#dae2fd",
                        "on-tertiary-container": "#ffddd5",
                        "primary": "#003ec7",
                        "on-background": "#191c1e",
                        "surface-tint": "#004ced",
                        "outline": "#737688",
                        "surface-container-high": "#e6e8ea",
                        "on-primary-container": "#dfe3ff",
                        "on-secondary-container": "#5c647a",
                        "surface-container-highest": "#e0e3e5",
                        "on-error": "#ffffff",
                        "secondary-fixed-dim": "#bec6e0",
                        "inverse-primary": "#b7c4ff",
                        "on-secondary-fixed-variant": "#3f465c",
                        "on-tertiary-fixed-variant": "#891e00",
                        "surface-dim": "#d8dadc",
                        "tertiary-fixed-dim": "#ffb4a1",
                        "on-secondary": "#ffffff",
                        "error-container": "#ffdad6",
                        "error": "#ba1a1a",
                        "surface": "#f7f9fb",
                        "surface-bright": "#f7f9fb",
                        "on-secondary-fixed": "#131b2e",
                        "surface-container-low": "#f2f4f6",
                        "on-tertiary": "#ffffff",
                        "tertiary-container": "#bf3003",
                        "on-primary-fixed": "#001452",
                        "on-surface": "#191c1e",
                        "on-tertiary-fixed": "#3c0800",
                        "secondary": "#565e74",
                        "secondary-fixed": "#dae2fd",
                        "inverse-on-surface": "#eff1f3",
                        "surface-container": "#eceef0",
                        "tertiary-fixed": "#ffdbd2",
                        "inverse-surface": "#2d3133",
                        "primary-container": "#0052ff",
                        "on-error-container": "#93000a",
                        "on-primary": "#ffffff",
                        "outline-variant": "#c3c5d9",
                        "on-primary-fixed-variant": "#0038b6",
                        "surface-variant": "#e0e3e5",
                        "on-surface-variant": "#434656",
                        "primary-fixed": "#dde1ff",
                        "background": "#f7f9fb"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "fontFamily": {
                        "headline": ["Manrope"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    }
                },
            },
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .no-border-tonal-shift { border: none !important; }
        .tonal-layering { border: none !important; }
        .flat-no-shadows { box-shadow: none !important; }
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3, .headline { font-family: 'Manrope', sans-serif; }
    </style>


<div class="flex pt-20">
 
<!-- Main Content Canvas -->
<main class="flex-1 md:ml-64 px-6 py-8 max-w-5xl w-full pb-32">
<WealthCardcomp></WealthCardcomp>


<!-- Transactions Section -->
<section>
<div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
<h3 class="font-headline font-bold text-2xl text-on-surface">Previous Transactions</h3>
<!-- Filters -->
<div class="flex flex-wrap gap-2">
<button class="bg-surface-container-low px-4 py-2 rounded-full text-xs font-semibold text-on-surface-variant border border-outline-variant/10 hover:bg-surface-container-high transition-colors">
                            Date: Last 30 Days
                        </button>
<button class="bg-surface-container-low px-4 py-2 rounded-full text-xs font-semibold text-on-surface-variant border border-outline-variant/10 hover:bg-surface-container-high transition-colors">
                            Type: All
                        </button>
<button @onclick="handleclick" class="bg-surface-container-low px-4 py-2 rounded-full text-xs font-semibold text-on-surface-variant border border-outline-variant/10 hover:bg-surface-container-high transition-colors">
                            Amount: $0 - $10k
                        </button>
</div>
</div>
<!-- Transaction List (No borders, tonal separation) -->
<div class="space-y-4">
<!-- Transaction Item -->
<div class="group flex items-center justify-between p-4 bg-surface-container-lowest rounded-xl hover:bg-surface-container-low transition-all duration-300">
<div class="flex items-center gap-4">
<div class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 group-hover:bg-white transition-colors">
<span class="material-symbols-outlined" data-icon="shopping_bag">shopping_bag</span>
</div>
<div>
<p class="font-headline font-bold text-on-surface">Apple Store Soho</p>
<p class="text-xs text-on-surface-variant">Technology • Oct 24, 2023</p>
</div>
</div>
<div class="text-right">
<p class="font-headline font-bold text-on-surface">- $1,299.00</p>
<p class="text-[10px] uppercase font-bold text-slate-400">Completed</p>
</div>
</div>
<!-- Transaction Item -->
<div class="group flex items-center justify-between p-4 bg-surface-container-lowest rounded-xl hover:bg-surface-container-low transition-all duration-300">
<div class="flex items-center gap-4">
<div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-primary group-hover:bg-white transition-colors">
<span class="material-symbols-outlined" data-icon="account_balance_wallet">account_balance_wallet</span>
</div>
<div>
<p class="font-headline font-bold text-on-surface">Internal Transfer</p>
<p class="text-xs text-on-surface-variant">Savings Account • Oct 22, 2023</p>
</div>
</div>
<div class="text-right">
<p class="font-headline font-bold text-primary">+ $5,000.00</p>
<p class="text-[10px] uppercase font-bold text-slate-400">Completed</p>
</div>
</div>
<!-- Transaction Item -->
<div class="group flex items-center justify-between p-4 bg-surface-container-lowest rounded-xl hover:bg-surface-container-low transition-all duration-300">
<div class="flex items-center gap-4">
<div class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 group-hover:bg-white transition-colors">
<span class="material-symbols-outlined" data-icon="restaurant">restaurant</span>
</div>
<div>
<p class="font-headline font-bold text-on-surface">The Gilded Cage</p>
<p class="text-xs text-on-surface-variant">Dining • Oct 21, 2023</p>
</div>
</div>
<div class="text-right">
<p class="font-headline font-bold text-on-surface">- $450.00</p>
<p class="text-[10px] uppercase font-bold text-slate-400">Completed</p>
</div>
</div>
<!-- Transaction Item -->
<div class="group flex items-center justify-between p-4 bg-surface-container-lowest rounded-xl hover:bg-surface-container-low transition-all duration-300">
<div class="flex items-center gap-4">
<div class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 group-hover:bg-white transition-colors">
<span class="material-symbols-outlined" data-icon="flight_takeoff">flight_takeoff</span>
</div>
<div>
<p class="font-headline font-bold text-on-surface">Delta Airlines</p>
<p class="text-xs text-on-surface-variant">Travel • Oct 18, 2023</p>
</div>
</div>
<div class="text-right">
<p class="font-headline font-bold text-on-surface">- $2,180.00</p>
<p class="text-[10px] uppercase font-bold text-slate-400">Completed</p>
</div>
</div>
</div>
<div class="mt-8 flex justify-center">
<button class="text-primary font-bold py-2 px-6 rounded-full hover:bg-primary/5 transition-colors">View All Transactions</button>
</div>
</section>
</main>
</div> 



@code {

    private void handleclick(MouseEventArgs args)
    {
        Console.WriteLine("Clicked");
    }
}
